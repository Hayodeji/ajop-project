PORT=3000
NODE_ENV=development

# Public URL of your Supabase project
SUPABASE_URL=https://your-project-ref.supabase.co

# Anon key — safe to expose, used for Auth user lookups in the guard
SUPABASE_ANON_KEY=your-anon-key

# Service role key — NEVER expose client-side. Used server-side for
# privileged DB operations (bypasses RLS; we still scope queries by admin_id).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of allowed origins for CORS (frontend dev + prod)
CORS_ORIGINS=http://localhost:5173

# WhatsApp Business API (360Dialog or Meta Cloud API)
# Leave blank to disable WhatsApp reminders
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=ajopot_verify

# Supabase Storage bucket name for payout receipts (create this bucket in your project)
SUPABASE_STORAGE_BUCKET=receipts

# Comma-separated list of super-admin phone numbers (normalised +234 format)
SUPER_ADMIN_PHONES=+2349065543761,+2347033139259
